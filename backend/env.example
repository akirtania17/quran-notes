# Quran Notes Backend environment variables
#
# IMPORTANT:
# - Copy this file to `.env` and fill in real values.
# - Never commit `.env` to git (it is ignored by `.gitignore`).
#
# Required
OPENAI_API_KEY=your_key_here

# Optional (defaults shown)
ENV=dev
PORT=8000
DATABASE_URL=sqlite:///./data/quran_notes.db
UPLOAD_DIR=./data/uploads
TMP_DIR=./data/tmp
CORS_ORIGINS=http://localhost:19006,http://localhost:8081
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_MB=60

# Storage backend (defaults shown)
# - local: store uploads in UPLOAD_DIR on disk
# - r2: Cloudflare R2 (S3-compatible)
STORAGE_BACKEND=local

# R2 / S3-compatible settings (required when STORAGE_BACKEND=r2)
# Example R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Optional prefix for all objects, e.g. quran-notes
S3_PREFIX=

# Processing reliability (defaults shown)
PROCESSING_LEASE_MINUTES=10
SWEEPER_ENABLED=true
SWEEPER_INTERVAL_SECONDS=300
STUCK_THRESHOLD_MINUTES=45
STUCK_MAX_AGE_MINUTES=120

# Models (defaults shown)
OPENAI_MODEL_TRANSCRIBE=whisper-1
OPENAI_MODEL_TRANSLATE=gpt-4o-mini
OPENAI_MODEL_SUMMARIZE=gpt-4o-mini


